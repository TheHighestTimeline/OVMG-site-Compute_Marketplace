# ─────────────────────────────────────────────────────────────────────
# OneVibe Compute Marketplace — environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# In Netlify, set these under Site settings → Environment variables.
# ─────────────────────────────────────────────────────────────────────

# Clerk (authentication) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Airtable (reservation records) — https://airtable.com/create/tokens
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Resend (transactional email) — https://resend.com/api-keys
RESEND_API_KEY=

# Middesk (EIN / business verification — optional)
MIDDESK_API_KEY=

# Stripe ACH payments — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get the webhook secret after: stripe listen --forward-to localhost:3000/api/payment/webhook
STRIPE_WEBHOOK_SECRET=

# Public site URL (used for Stripe redirect URLs in production)
NEXT_PUBLIC_SITE_URL=
